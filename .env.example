# AI_API_KEY: Required for AI API calls.
# Your deployment platform may inject this at runtime from configured secrets.
# Configure this via your environment/secrets manager.
AI_API_KEY="MY_AI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Your deployment platform may inject this at runtime with the hosted service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
